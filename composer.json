{
    "name": "omid-khadem/exception-handler",
    "description": "A library to convert exception to a response object",
    "type": "library",
    "require-dev": {
        "phpunit/phpunit": "7.1|^8.0",
        "mockery/mockery": "1.3.*"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Omid Khadem",
            "email": "khadem.omid@gmail.com"
        }
    ],
    "require": {
        "ext-json": "*",
        "psr/http-message": "^1.0",
        "psr/http-factory": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Khadem\\ExceptionHandler\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Khadem\\Tests\\ExceptionHandler\\": "tests"
        }
    }
}
